{% extends "base.html.twig" %}

{% block content %}

<body style="font-family: Inter;">
    <h1 class="mt-3 fw-bold text-center" style="font-size: 50px;">Wish List !</h1>
<hr class="border border-dark opacity-100">
    
<div class="border border-dark border-3 rounded-2 px-5 py-3 w-50 mx-auto mt-4 position-relative">
 <h3 class="float-none w-auto fw-bold">Nom de l'offre</h3>
 <p class="mb-0" >Nom de l'entreprise</p>
 <p class="mb-0">Lieu de l'entreprise</p>
 <p class="mt-5">Date de publication</p>

<div class="position-absolute top-0 end-0 mt-3 me-3" id="Coeurdéroulant" data-bs-toggle="dropdown" aria-expanded="false">
                    <a>  
                        <svg class="Wishlist" height="45" fill="red" stroke="black" stroke-width="30"
                            viewBox="0 0 512 512"
                            aria-label="Wishlist"
                            role="button"
                            xmlns="http://www.w3.org/2000/svg">
                            <path d="M256 472
                                    C256 472 40 312 40 160
                                    C40 72 104 32 168 32
                                    C216 32 256 80 256 80
                                    C256 80 296 32 344 32
                                    C408 32 472 72 472 160
                                    C472 312 256 472 256 472 Z"/>
                        </svg>
                    </a>

                <ul class="dropdown-menu">
                     <li><a class="dropdown-item text-center text-danger fw-bold text-opacity-100">Supprimer</a></li>
</div>
 
