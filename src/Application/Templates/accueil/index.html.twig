{% extends "layouts/base.html.twig" %}

{% block content %}

	<div class="position-relative">
		<h1 class="position-absolute justify-content-start text-white" style="font-size: 150px;">
			Bienvenue !
		</h1>
		<img src="/assets/images/bg.jpg" alt="Image-Background" class="w-100" style="object-fit: cover; object-position:top; height: 400px; overflow:hidden;">
	</div>
	<div id="carouselExample" class="carousel slide">
		<div class="carousel-inner">

			<div class="carousel-item active text-center py-5">
				<h2 class="display-4 fw-bold">{{ totalOffres }}</h2>
				<p class="lead">Offres de stage disponibles</p>
			</div>

			<div class="carousel-item text-center py-5">
				<h2 class="display-4 fw-bold">{{ totalEntreprises }}</h2>
				<p class="lead">Entreprises partenaires</p>
			</div>

			<div class="carousel-item text-center py-5">
				<h2 class="display-4 fw-bold">{{ totalEtudiants }}</h2>
				<p class="lead">Étudiants inscrits</p>
			</div>

		</div>

		<button class="carousel-control-prev" type="button" data-bs-target="#carouselExample" data-bs-slide="prev" style="filter: invert(1);">
			<span class="carousel-control-prev-icon" aria-hidden="true"></span>
			<span class="visually-hidden">Previous</span>
		</button>
		<button class="carousel-control-next" type="button" data-bs-target="#carouselExample" data-bs-slide="next" style="filter: invert(1);">
			<span class="carousel-control-next-icon" aria-hidden="true"></span>
			<span class="visually-hidden">Next</span>
		</button>
	</div>
{% endblock %}
