<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion - StageHub</title>
    <link rel="stylesheet" href="/assets/css/style-Accueil.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body style="font-family: Inter; height:100vh" class="align-items-center justify-content-center d-flex bg-light">

    {% if not est_connecte %}
        <form action="/connexion" method="POST" class="w-50">
            <section class="border border-success border-3 rounded-2 px-5 py-3 bg-white shadow-sm">
                <h1 class="text-center fs-1 mb-4 fw-bold">Connexion</h1>

                {% if error %}
                    <div class="alert alert-danger text-center">{{ error }}</div>
                {% endif %}

                <div class="input-box position-relative mb-4">
                    <input type="text" name="email" placeholder="email" class="border border-dark border-2 form-control rounded-pill px-3 py-2" required>
                </div>

                <div class="input-box mb-4">
                    <input type="password" name="password" placeholder="Mot de passe" class="form-control rounded-pill border-2 border-dark px-3" required>
                </div>

                <button type="submit" class="btn btn-success rounded-pill fw-bold w-100">
                    Se connecter
                </button>
            </section>
        </form>
    {% else %}
        <section class="border border-success border-3 rounded-2 px-5 py-4 bg-white shadow-sm text-center w-50">
            <h1 class="fs-2 mb-4 fw-bold">Tu es déjà connecté !</h1>
            <p class="mb-4">Il n'est pas nécessaire de te reconnecter.</p>
            <a href="/accueil-co" class="btn btn-success rounded-pill fw-bold w-100">
                Retourner à mon accueil
            </a>
        </section>
    {% endif %}

</body>
</html>