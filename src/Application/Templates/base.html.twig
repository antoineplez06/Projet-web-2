<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}StageHub{% endblock title %}</title>
    
    <link rel="stylesheet" href="/assets/css/style-Accueil.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</head>

<body class="bg-light" style="font-family: Inter;">

    <header class="header d-flex align-items-center gap-4">
        <img src="/assets/images/logo.png" alt="StageHub" style="height:100px;">

        <nav class="d-flex justify-content-center align-items-start gap-4 list-unstyled fs-5">
            <a class="text-decoration-none text-dark" href="{{user ? '/accueil-co' : '/'}}">
                <li>Page d'accueil</li>
            </a>
            
            <li class="Rechercher dropdown">
                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                    Rechercher
                </a>
                <ul class="dropdown-menu">
                    <li>
                        <a class="dropdown-item" href="{{ user ? '/offres' : '/offres-an' }}">Offres</a>
                    </li>
                    <li>
                        <a class="dropdown-item" href="{{user ? '/entreprises' : '/entreprises-an' }}">Entreprises</a>
                    </li>
                </ul>
            </li>
        </nav>

        <div class="d-flex justify-content-end align-items-center ms-auto gap-3">
            
            {% if user %}
                <a href="/wishlist">
                    <svg class="Wishlist" height="45" fill="none" stroke="black" stroke-width="30" viewBox="0 0 512 512">
                        <path d="M256 472 C256 472 40 312 40 160 C40 72 104 32 168 32 C216 32 256 80 256 80 C256 80 296 32 344 32 C408 32 472 72 472 160 C472 312 256 472 256 472 Z"/>
                    </svg>
                </a>

                <a href="/candidatures">
                    <svg class="Candidatures" height="50" fill="none" stroke="black" stroke-width="30" viewBox="0 0 512 512">
                        <path d="M160 64 H352 L416 128 V448 H160 Z M352 64 V128 H416 M112 96 L208 288 L176 320 L80 128 Z"/>
                    </svg>
                </a>

                <div class="dropdown me-4">
                    <a href="#" class="d-flex align-items-center text-dark text-decoration-none" id="Profildéroulant" data-bs-toggle="dropdown" aria-expanded="false">
                        <svg class="Profil" height="58" stroke="black" stroke-width="35" viewBox="0 0 512 512">
                            <circle cx="256" cy="160" r="96"/>
                            <path d="M96 416 C96 336 176 304 256 304 C336 304 416 336 416 416"/>
                        </svg>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li class="text-center fw-bold border-bottom border-dark px-2">{{ user.prenom }} {{ user.nom }}</li>
                        <li>
                            <a class="dropdown-item text-center text-danger fw-bold" href="{{ url_for('deconnexion') }}">
                                Me déconnecter
                            </a>
                        </li>
                    </ul>
                </div>

            {% else %}
                <a href="/connexion" class="fs-5 btn rounded-pill px-4 py-2 me-4 text-dark border border-dark" style="background-color: #8FB4B0">
                    Connexion
                </a>
            {% endif %}

        </div>
    </header>

    <main>
        {% block content %}{% endblock %}
    </main>

    <footer id="footer" class="text-center py-3">
        {% block footer %}
            &copy; Copyright 2026 by <a href="https://example.com/">StageHub</a>.
        {% endblock %}
    </footer>

</body>
</html>