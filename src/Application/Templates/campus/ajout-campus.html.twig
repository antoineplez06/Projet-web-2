{% extends "layouts/base.html.twig" %}

{% block title %}Ajouter un campus
{% endblock %}

{% block content %}

<div class="row justify-content-center">
		<div class="col-md-8 col-lg-6">
			<div class="card shadow">
				<div class="card-header bg-primary text-white">
					<h4 class="mb-0">Nouveau campus</h4>
				</div>
				<div class="card-body">
					<form
						action="/ajout-campus" method="POST">

						<div class="mb-3">
							<label for="nom" class="form-label font-weight-bold">Ville du campus</label>
							<input type="text" class="form-control" id="nom" name="nom" placeholder="Ex: Reims" value="{{ ville }}" required>
						</div>

{% endblock %}