{% extends "layouts/base.html.twig" %}

{% block content %}

	{# --- ADAPTATION DU TITRE SELON LE RÔLE --- #}
	{% if userRole == 'etudiant' %}
		<h1 class="mt-3 fw-bold text-center" style="font-size: 50px;">Mes candidatures</h1>
	{% else %}
		<h1 class="mt-3 fw-bold text-center" style="font-size: 50px;">Candidatures des étudiants</h1>
	{% endif %}

	<hr class="border border-dark opacity-100">

	<h2 class="mt-2 fw-bold ms-4">Réponses</h2>

	{% set a_reponse = false %}
	{% for candidature in candidatures %}
		{% if candidature.statut == 'Accepté' or candidature.statut == 'Refusé' %}
			{% set a_reponse = true %}
			{% set offre = candidature.offre %}

			<div
				class="border border-dark border-3 rounded-2 px-5 py-3 w-50 mx-auto mt-4 position-relative bg-white shadow-sm">

				{# --- ÉTAPE 5 : AFFICHAGE DU NOM DU CANDIDAT (SI PILOTE/ADMIN) --- #}
				{% if userRole != 'etudiant' %}
					<p class="text-primary fw-bold mb-1">
						Candidat :
						{{ candidature.etudiant.prenom }}
						{{ candidature.etudiant.nom }}
					</p>
				{% endif %}

				<h3 class="float-none w-auto fw-bold">{{ offre.nom }}</h3>

				<p class="mb-0 text-muted fw-bold">{{ offre.entreprise.nom }}</p>

				<p class="mb-0">{{ offre.presentielOuDistanciel }}</p>
				<p class="mt-5 text-muted">Publié le :
					{{ offre.date|date("d/m/Y") }}</p>

				<h3 class="border border-dark px-5 py-2 position-absolute top-0 end-0 mt-3 me-3
					                                                                {% if candidature.statut == 'Refusé' %}
					                                                                    bg-danger text-white
					                                                                {% elseif candidature.statut == 'Accepté' %}
					                                                                    bg-success text-white
					                                                                {% else %}
					                                                                    bg-light
					                                                                {% endif %}" style="font-size: 1.2rem;">
					{{ candidature.statut }}
				</h3>

				{# CORRECTION 1 ICI #}
				<button class="border border-dark rounded-pill px-4 py-2 position-absolute bottom-0 end-0 mb-3 me-3 bg-dark text-white hover-shadow" data-bs-toggle="modal" data-bs-target="#VoirOffre{{ candidature.idCandidature }}">
					Voir l'offre
				</button>
			</div>
		{% endif %}
	{% endfor %}

	{% if not a_reponse %}
		<p class="ms-5 text-muted">Aucune réponse pour le moment.</p>
	{% endif %}

	<h2 class="mt-5 fw-bold ms-4">En cours de traitement</h2>

	{% set a_en_cours = false %}
	{% for candidature in candidatures %}
		{% if candidature.statut == 'En cours de traitement' or candidature.statut == 'En attente' %}
			{% set a_en_cours = true %}
			{% set offre = candidature.offre %}

			<div
				class="border border-dark border-3 rounded-2 px-5 py-3 w-50 mx-auto mt-4 position-relative bg-white shadow-sm">

				{# --- ÉTAPE 5 : AFFICHAGE DU NOM DU CANDIDAT (SI PILOTE/ADMIN) --- #}
				{% if userRole != 'etudiant' %}
					<p class="text-primary fw-bold mb-1">
						Candidat :
						{{ candidature.etudiant.prenom }}
						{{ candidature.etudiant.nom }}
					</p>
				{% endif %}

				<h3 class="float-none w-auto fw-bold">{{ offre.nom }}</h3>

				<p class="mb-0 text-muted fw-bold">{{ offre.entreprise.nom }}</p>

				<p class="mb-0">{{ offre.presentielOuDistanciel }}</p>
				<p class="mt-5 text-muted">Publié le :
					{{ offre.date|date("d/m/Y") }}</p>

				<h3 class="border border-dark px-4 py-2 position-absolute top-0 end-0 mt-3 me-3 bg-warning" style="font-size: 1.1rem;">
					En cours
				</h3>

				{# CORRECTION 2 ICI #}
				<button class="border border-dark rounded-pill px-4 py-2 position-absolute bottom-0 end-0 mb-3 me-3 bg-dark text-white hover-shadow" data-bs-toggle="modal" data-bs-target="#VoirOffre{{ candidature.idCandidature }}">
					Voir l'offre
				</button>
			</div>
		{% endif %}
	{% endfor %}

	{% if not a_en_cours %}
		<p class="ms-5 text-muted">Aucune candidature en cours.</p>
	{% endif %}

	{# --- AJOUT DES MODALS --- #}
	{% for candidature in candidatures %}
		{% set offre = candidature.offre %}

		{# CORRECTION 3 ICI #}
		<div class="modal fade" id="VoirOffre{{ candidature.idCandidature }}" tabindex="-1" aria-hidden="true">
			<div class="modal-dialog modal-lg">
				<div class="modal-content">
					<div class="modal-header bg-dark text-white">
						<h5 class="modal-title">{{ offre.nom }}
							-
							{{ offre.entreprise.nom }}</h5>
						<button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
					</div>
					<div
						class="modal-body">

						{# --- DOSSIER DE CANDIDATURE (Maintenant visible par TOUT LE MONDE) --- #}
						<div class="bg-light p-3 rounded mb-4 border">
							<h5 class="text-primary fw-bold border-bottom pb-2">
								{% if userRole == 'etudiant' %}
									Mon dossier de candidature
								{% else %}
									Dossier de
									{{ candidature.etudiant.prenom }}
									{{ candidature.etudiant.nom }}
								{% endif %}
							</h5>

							<h6 class="fw-bold mt-3">Lettre de motivation :</h6>
							{% if candidature.lettreMotivation %}
								<p class="bg-white p-3 border rounded" style="white-space: pre-wrap;">{{ candidature.lettreMotivation }}</p>
							{% else %}
								<p class="text-muted fst-italic">Aucune lettre fournie.</p>
							{% endif %}

							<h6 class="fw-bold mt-3">Curriculum Vitae (CV) :</h6>
							{% if candidature.cv %}
								<a href="/uploads/cv/{{ candidature.cv }}" target="_blank" class="btn btn-outline-primary">
									<i class="bi bi-file-earmark-pdf"></i>
									Télécharger / Voir le CV
								</a>
							{% else %}
								<p class="text-muted fst-italic">Aucun CV fourni.</p>
							{% endif %}
						</div>
						{# ----------------------------------------------------------------- #}

						<h6 class="fw-bold text-secondary">Détails de l'offre :</h6>
						<p>
							<strong>Lieu :</strong>
							{{ offre.lieu }}</p>
						<p>
							<strong>Rémunération :</strong>
							{{ offre.remuneration }}
							€</p>
						<p>{{ offre.description|nl2br }}</p>
					</div>
				</div>
			</div>
		</div>
	{% endfor %}
{% endblock %}
