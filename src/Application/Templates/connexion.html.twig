
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion - StageHub</title>
    <link rel="stylesheet" href="/assets/css/style-Accueil.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body style="font-family: Inter; height:100vh" class="align-items-center justify-content-center d-flex bg-light">

    <form action="/connexion" method="POST" class="w-50">
        <section class="border border-success border-3 rounded-2 px-5 py-3 bg-white shadow-sm">

            <h1 class="text-center fs-1 mb-4 fw-bold" style="font-family:'Trebuchet MS', sans-serif">Connexion</h1>

            <div class="input-box position-relative mb-4">
                <input type="text" name="email" placeholder="email" class="border border-dark border-2 form-control rounded-pill px-3 py-2" required>
            </div>

            <div class="input-box position-relative mb-4">
                <input type="password" name="password" placeholder="Mot de passe" class="border border-dark border-2 form-control rounded-pill px-3 py-2" required>
            </div>

            <div>
                <a class="d-flex text-dark justify-content-start mb-4 text-decoration-none" href="#">Mot de passe oublié ?</a>
            </div>

            <button type="submit" class="form-control rounded-pill px-4 py-2 bg-success text-white fw-bold w-25">
                Se connecter
            </button>

        </section>
    </form>

</body>
</html>