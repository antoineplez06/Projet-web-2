{% extends "layouts/base.html.twig" %}

{% block title %}Liste des Entreprises{% endblock %}

{% block content %}

    {# Barre de recherche #}
    <form class="d-flex mt-4 mx-auto w-50" method="GET" action="">
        <input class="form-control me-4 border border-dark border-2" type="search" name="search" value="{{ filtres.search|default('') }}" placeholder="Rechercher une entreprise..." aria-label="Rechercher">
        <button class="btn btn-outline-secondary" type="submit">Rechercher</button>
    </form>

    {% for ent in entreprises %}
        <div class="border border-dark border-3 rounded-2 px-5 py-3 w-50 mx-auto mt-4 position-relative bg-white shadow-sm">
            <h3 class="float-none w-auto fw-bold mb-1">{{ ent.nom }}</h3>
            
            {# --- AFFICHAGE DES ÉTOILES (MOYENNE) --- #}
            <div class="mb-3">
                {# On arrondit la note pour les étoiles, mais on garde la décimale pour le texte #}
                {% set noteValue = ent.note|default(0) %}
                {% set noteArrondie = noteValue|round %}
                
                {% if noteValue > 0 %}
                    {% for i in 1..5 %}
                        <i class="bi bi-star{{ i <= noteArrondie ? '-fill' : '' }} text-warning"></i>
                    {% endfor %}
                    <span class="ms-2 text-dark fw-bold small">Note :{{ noteValue }}/5</span>
                {% else %}
                    <span class="text-muted small"><i>Aucune note</i></span>
                {% endif %}
            </div>

            <p class="mb-0 text-muted"><strong>Domaine :</strong> {{ ent.domaine }}</p>
            <p class="mb-0"><strong>Lieu :</strong> {{ ent.adresse }}</p>
            
            <p class="mt-4 text-muted small">SIRET : <code>{{ ent.siret }}</code></p>

            <div class="position-absolute top-0 end-0 mt-3 me-3">
                <span class="badge border border-dark text-dark bg-light p-2">{{ ent.taille }}</span>
            </div>

            {# --- SECTION BOUTONS --- #}
            <div class="position-absolute bottom-0 end-0 mb-3 me-3 d-flex gap-2">
                <button type="button" class="btn btn-dark rounded-pill px-3 shadow-sm" data-bs-toggle="modal" data-bs-target="#ModalOffres{{ ent.id }}">
                    Voir les offres ({{ ent.offres|length }})
                </button>

                <button type="button" class="border border-dark rounded-pill px-4 py-2 bg-light hover-shadow" data-bs-toggle="modal" data-bs-target="#VoirEntreprise{{ ent.id }}">
                    Détails / Noter
                </button>
            </div>

            {# --- MODAL 1 : DÉTAILS ENTREPRISE + FORMULAIRE DE NOTE --- #}
            <div class="modal fade" id="VoirEntreprise{{ ent.id }}" tabindex="-1">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h2 class="fw-bold">{{ ent.nom }}</h2>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body p-4">
                            <p><strong>Adresse :</strong> {{ ent.adresse }}</p>
                            <p><strong>SIRET :</strong> {{ ent.siret }}</p>
                            <p><strong>Taille :</strong> {{ ent.taille }}</p>
                            <h4 class="fw-bold mt-4">À propos</h4>
                            <p class="mb-1 text-muted">{{ ent.domaine|default('Aucune description disponible.')|nl2br }}</p>

                            <hr class="my-4">

                            {# --- FORMULAIRE DE NOTATION --- #}
                            <h4 class="fw-bold">Évaluer cette entreprise</h4>
                            <p class="text-muted small">Votre note sera ajoutée à la moyenne actuelle de l'entreprise.</p>
                            
                            <form action="{{ url_for('entreprise-noter', { 'id': ent.id }) }}" method="POST" class="mt-3 bg-light p-3 rounded border border-warning">
                                <div class="d-flex align-items-center gap-3">
                                    <label class="fw-bold">Votre note :</label>
                                    <select name="note" class="form-select w-50 border-dark">
                                        <option value="5">5 ★★★★★ (Excellent)</option>
                                        <option value="4" selected>4 ★★★★☆ (Très bien)</option>
                                        <option value="3">3 ★★★☆☆ (Moyen)</option>
                                        <option value="2">2 ★★☆☆☆ (Décevant)</option>
                                        <option value="1">1 ★☆☆☆☆ (À éviter)</option>
                                    </select>
                                    <button type="submit" class="btn btn-warning fw-bold border-dark shadow-sm">Valider la note</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            {# --- MODAL 2 : LISTE DES OFFRES (Version complète) --- #}
            <div class="modal fade" id="ModalOffres{{ ent.id }}" tabindex="-1">
                <div class="modal-dialog modal-xl modal-dialog-scrollable">
                    <div class="modal-content">
                        <div class="modal-header bg-dark text-white">
                            <h5 class="modal-title">Stages disponibles chez {{ ent.nom }}</h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body p-4 bg-light">
                            {% if ent.offres is not empty %}
                                <div class="row">
                                    {% for offre in ent.offres %}
                                        <div class="col-12 mb-4">
                                            <div class="card border-dark border-2 shadow-sm">
                                                <div class="card-body p-4">
                                                    <div class="d-flex justify-content-between align-items-start">
                                                        <div>
                                                            <h4 class="fw-bold text-dark mb-1">{{ offre.nom }}</h4>
                                                            <p class="text-muted mb-3 small">
                                                                <i class="bi bi-geo-alt"></i> {{ offre.lieu }} | Publié le {{ offre.date|date("d/m/Y") }}
                                                            </p>
                                                        </div>
                                                        <span class="badge bg-success fs-6">{{ offre.remuneration }} €</span>
                                                    </div>
                                                    <hr>
                                                    <div class="row">
                                                        <div class="col-md-8">
                                                            <h5 class="fw-bold">Description</h5>
                                                            <p class="text-dark small">{{ offre.description|nl2br }}</p>
                                                        </div>
                                                        <div class="col-md-4 border-start border-2 text-center">
                                                            <p class="mb-2"><strong>Postulants :</strong> {{ offre.nombreEtudiantPostule|default(0) }}</p>
                                                            <a href="{{ url_for('page-postuler', { 'id': offre.idOffre }) }}" class="btn btn-primary w-100">Postuler</a>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% else %}
                                <div class="text-center py-5">
                                    <h4 class="text-muted">Aucune offre pour le moment.</h4>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    {% endfor %}

    {# Pagination (Une seule fois !) #}
    {% if nombrePages > 1 %}
    <nav aria-label="Page navigation" class="mt-5 mb-5">
        <ul class="pagination justify-content-center">
            <li class="page-item {{ pageActuelle <= 1 ? 'disabled' : '' }}">
                <a class="page-link text-dark border-dark" href="{{ url_for('liste-entreprises', { 'page': pageActuelle - 1 }) }}">Précédent</a>
            </li>
            {% for i in 1..nombrePages %}
                <li class="page-item {{ i == pageActuelle ? 'active' : '' }}">
                    <a class="page-link {{ i == pageActuelle ? 'bg-dark text-white border-dark' : 'text-dark border-dark' }}" href="{{ url_for('liste-entreprises', { 'page': i }) }}">{{ i }}</a>
                </li>
            {% endfor %}
            <li class="page-item {{ pageActuelle >= nombrePages ? 'disabled' : '' }}">
                <a class="page-link text-dark border-dark" href="{{ url_for('liste-entreprises', { 'page': pageActuelle + 1 }) }}">Suivant</a>
            </li>
        </ul>
    </nav>
    {% endif %}

{% endblock %}