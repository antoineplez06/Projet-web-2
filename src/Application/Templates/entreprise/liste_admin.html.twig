{% extends "layouts/base.html.twig" %}

{% block title %}Liste des Entreprises (Admin)
{% endblock %}

{% block content %}

	<div class="d-flex justify-content-between align-items-center mb-4">
		<h1>Liste des Entreprises</h1>
		<a class="btn btn-primary" href="{{ url_for('ajout-entreprise') }}">Ajouter une entreprise</a>
	</div>

	<div class="row mb-3">
		<div class="col-md-6">
			<form method="GET" action="{{ url_for('entreprises-admin') }}" class="d-flex">
				<input type="text" name="q" class="form-control me-2" placeholder="Rechercher par nom..." value="{{ searchTerm }}">
				<button type="submit" class="btn btn-outline-secondary">Rechercher</button>
				{% if searchTerm %}
					<a href="{{ url_for('entreprises-admin') }}" class="btn btn-link">Réinitialiser</a>
				{% endif %}
			</form>
		</div>
	</div>

	<div class="card shadow-sm">
		<div class="card-body p-0">
			<table
				class="table table-hover mb-0 align-middle">
				{# align-middle pour centrer verticalement #}
				<thead class="table-light">
					<tr>
						<th>ID</th>
						<th>Nom / Note</th>
						{# On combine ici ou on crée une colonne #}
						<th>Adresse</th>
						<th>SIRET</th>
						<th>Domaine</th>
						<th>Taille</th>
						<th class="text-end px-3">Actions</th>
					</tr>
				</thead>
				<tbody>
					{% for ent in entreprises %}
						<tr>
							<td class="text-muted">{{ ent.id }}</td>
							<td>
								<strong>{{ ent.nom }}</strong><br>
								{# Affichage de la note en petit sous le nom #}
								<small class="text-warning fw-bold">
									Note :
									{{ ent.note|default(0) > 0 ? ent.note ~ '/5' : 'n/a' }}
								</small>
							</td>
							<td>{{ ent.adresse }}</td>
							<td>
								<code>{{ ent.siret }}</code>
							</td>
							<td>{{ ent.domaine }}</td>
							<td>
								<span class="badge border text-dark bg-light">{{ ent.taille }}</span>
							</td>
							<td class="text-end px-3">
								<div
									class="btn-group">
									{# BOUTON NOTER (Ouvre une modal ou une page) #}
									<button type="button" class="btn btn-sm btn-outline-info" data-bs-toggle="modal" data-bs-target="#ModalNoteAdmin{{ ent.id }}">
										Noter
									</button>

									<a href="{{ url_for('modifier-entreprise', { 'id': ent.id }) }}" class="btn btn-sm btn-outline-warning">Modifier</a>

									<form action="{{ url_for('supprimer-entreprise', { 'id': ent.id }) }}" method="POST" class="d-inline" onsubmit="return confirm('Supprimer cette entreprise ?')">
										<button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
									</form>
								</div>

								{# --- PETITE MODAL RAPIDE POUR NOTER (Admin) --- #}
								<div class="modal fade text-start" id="ModalNoteAdmin{{ ent.id }}" tabindex="-1">
									<div class="modal-dialog modal-sm modal-dialog-centered">
										<div class="modal-content">
											<form action="{{ url_for('entreprise-noter', { 'id': ent.id }) }}" method="POST">
												<div class="modal-header">
													<h6 class="modal-title">Noter
														{{ ent.nom }}</h6>
													<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
												</div>
												<div class="modal-body">
													<select name="note" class="form-select border-dark">
														{% for i in 5..1 %}
															<option value="{{ i }}" {{ ent.note|round == i ? 'selected' : '' }}>{{ i }}/5</option>
														{% endfor %}
													</select>
												</div>
												<div class="modal-footer p-2">
													<button type="submit" class="btn btn-primary btn-sm w-100">Enregistrer</button>
												</div>
											</form>
										</div>
									</div>
								</div>
								{# --- FIN MODAL --- #}

							</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="7" class="text-center py-4 text-muted">Aucune entreprise trouvée.</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>
	</div>

	{# Pagination #}
	{% if nombrePages > 1 %}
		<nav aria-label="Page navigation" class="mt-4">
			<ul class="pagination justify-content-center">
				<li class="page-item {{ pageActuelle <= 1 ? 'disabled' }}">
					<a class="page-link" href="{{ url_for('entreprises-admin', { 'page': pageActuelle - 1 }) }}">Précédent</a>
				</li>
				{% for i in 1..nombrePages %}
					<li class="page-item {{ i == pageActuelle ? 'active' }}">
						<a class="page-link" href="{{ url_for('entreprises-admin', { 'page': i }) }}">{{ i }}</a>
					</li>
				{% endfor %}
				<li class="page-item {{ pageActuelle >= nombrePages ? 'disabled' }}">
					<a class="page-link" href="{{ url_for('entreprises-admin', { 'page': pageActuelle + 1 }) }}">Suivant</a>
				</li>
			</ul>
		</nav>
	{% endif %}

{% endblock %}
