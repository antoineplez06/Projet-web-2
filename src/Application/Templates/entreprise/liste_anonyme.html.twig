{% extends "layouts/base.html.twig" %}

{% block content %}

	<div class="row mb-3 mt-4 justify-content-center px-2">
		<div class="col-12 col-sm-10 col-md-8 col-lg-6">
			<form method="GET" action="{{ url_for('entreprises-an') }}" class="d-flex flex-column flex-sm-row gap-2">
				<input type="text" name="q" class="form-control" placeholder="Rechercher par nom..." value="{{ searchTerm }}">
				<button type="submit" class="btn btn-outline-secondary flex-shrink-0">Rechercher</button>
				{% if searchTerm %}
					<a href="{{ url_for('entreprises-an') }}" class="btn btn-link">Réinitialiser</a>
				{% endif %}
			</form>
		</div>
	</div>

	{% for ent in entreprises %}
		<div class="row mt-4 px-2 justify-content-center">
			<div class="col-12 col-sm-10 col-lg-8 col-xl-7">
				<div class="border border-dark border-3 rounded-2 px-3 px-md-5 py-3 bg-white shadow-sm">
					<div class="d-flex justify-content-between align-items-start gap-2 mb-3">
						<h3 class="fw-bold mb-0 flex-grow-1 text-break">{{ ent.nom }}</h3>
						<span class="badge border border-dark text-dark bg-light p-2 flex-shrink-0">{{ ent.taille }}</span>
					</div>
					
					<p class="mb-2 text-muted small">
						<strong>Domaine :</strong>
						<span class="text-break">{{ ent.domaine }}</span>
					</p>
					<p class="mb-3">
						<strong>Lieu :</strong>
						<span class="text-break">{{ ent.adresse }}</span>
					</p>

					<p class="mt-3 text-muted small">
						<strong>SIRET :</strong>
						<code class="text-break">{{ ent.siret }}</code>
					</p>

					<div class="d-flex justify-content-center mt-4">
						<button type="button" class="btn btn-outline-dark rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#VoirEntreprise{{ ent.id }}">
							Voir l'entreprise
						</button>
					</div>

					{# Modal de détails #}
					<div class="modal fade" id="VoirEntreprise{{ ent.id }}" tabindex="-1">
						<div class="modal-dialog modal-lg modal-dialog-scrollable">
							<div class="modal-content">
								<div class="modal-header flex-column align-items-start border-bottom">
									<button type="button" class="btn-close align-self-end mb-2" data-bs-dismiss="modal"></button>
									<div class="w-100">
										<h2 class="fw-bold text-break">{{ ent.nom }}</h2>
										<p class="mb-1 text-muted small text-break">{{ ent.adresse }}</p>
										<p class="text-dark fw-bold small">Taille : {{ ent.taille }}</p>
									</div>
								</div>

								<div class="modal-body px-3 px-md-4">
									<h4 class="fw-bold">Informations légales</h4>
									<p>
										<strong>SIRET :</strong>
										<code class="text-break">{{ ent.siret }}</code>
									</p>

									<h4 class="fw-bold mt-4">À propos</h4>
									<p class="mb-1 text-muted text-break">{{ ent.domaine|default('Aucune description disponible.')|nl2br }}</p>
								</div>

								<div class="modal-footer">
									<button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Fermer</button>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	{% else %}
		<div class="text-center mt-5 px-3">
			<h4 class="fw-bold text-muted">Aucune entreprise ne correspond à vos critères.</h4>
		</div>
	{% endfor %}

	{# Pagination #}
	{% if nombrePages > 1 %}
		<nav aria-label="Page navigation" class="mt-4">
			<ul class="pagination justify-content-center">
				<li class="page-item {{ pageActuelle <= 1 ? 'disabled' : '' }}">
					<a class="page-link text-dark" href="{{ url_for('liste-entreprises', { 'page': pageActuelle - 1 }) }}">Précédent</a>
				</li>

				{% for i in 1..nombrePages %}
					<li class="page-item {{ i == pageActuelle ? 'active' : '' }}">
						<a class="page-link {{ i == pageActuelle ? 'bg-dark text-white' : 'text-dark' }}" href="{{ url_for('liste-entreprises', { 'page': i }) }}">{{ i }}</a>
					</li>
				{% endfor %}

				<li class="page-item {{ pageActuelle >= nombrePages ? 'disabled' : '' }}">
					<a class="page-link text-dark" href="{{ url_for('liste-entreprises', { 'page': pageActuelle + 1 }) }}">Suivant</a>
				</li>
			</ul>
		</nav>
	{% endif %}

{% endblock %}
