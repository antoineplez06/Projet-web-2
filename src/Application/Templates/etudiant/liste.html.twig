{% extends "layouts/base.html.twig" %}

{% block title %}Liste des Etudiants
{% endblock %}

{% block content %}
	<div class="d-flex justify-content-between align-items-center mb-4">
		<h1>Liste des étudiants</h1>
		<a class="btn btn-primary" href="{{ url_for('ajout-etudiant') }}">Ajouter un étudiant</a>
	</div>

	<div class="card shadow-sm">
		<div class="card-body p-0">
			<table class="table table-hover mb-0">
				<thead class="table-light">
					<tr>
						<th>ID</th>
						<th>prenom</th>
						<th>nom</th>
						<th>genre</th>
						<th>numéro</th>
						<th>date de naissance</th>
						<th>mail</th>
						<th>campus</th>
						<th>promo</th>
						<th class="text-end">Actions</th>
					</tr>
				</thead>
				<tbody>
					{% for etu in etudiant %}
						<tr>
							<td>{{ etu.id }}</td>
							<td>{{ etu.prenom }}</td>
							<td>
								<strong>{{ etu.nom }}</strong>
							</td>
							<td>{{ etu.genre }}</td>
							<td>{{ etu.numeroTelephone }}</td>
							<td>{{ etu.dateNaissance|date("d/m/Y") }}</td>
							<td>{{ etu.email }}</td>
							<td>{{ etu.campus }}</td>
							<td>{{ etu.promo }}</td>


							<td class="text-end">
                                <a href="{{ url_for('modifier-etudiant', { 'id': etu.id }) }}" class="btn btn-sm btn-outline-warning">Modifier</a>
                                    <form action="{{ url_for('supprimer-etudiant', { 'id': etu.id }) }}" method="POST" class="d-inline" onsubmit="return confirm('Supprimer cette etudiant ?')">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
                                    </form>
							</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="5" class="text-center py-4">Aucun étudiant trouvé.</td>
						</tr>
					{% endfor %}
				</tbody>
			</table>
		</div>
	</div>


	<nav aria-label="Page navigation">
		<ul class="pagination">

			<li class="page-item {{ pageActuelle <= 1 ? 'disabled' }}">
				<a class="page-link" href="{{ url_for('liste-etudiant', { 'page': pageActuelle - 1 }) }}">Précédent</a>
			</li>

			{% for i in 1..nombrePages %}
				<li class="page-item {{ i == pageActuelle ? 'active' }}">
					<a class="page-link" href="{{ url_for('liste-etudiant', { 'page': i }) }}">{{ i }}</a>
				</li>
			{% endfor %}

			<li class="page-item {{ pageActuelle >= nombrePages ? 'disabled' }}">
				<a class="page-link" href="{{ url_for('liste-etudiant', { 'page': pageActuelle + 1 }) }}">Suivant</a>
			</li>

		</ul>
	</nav>

{% endblock %}
