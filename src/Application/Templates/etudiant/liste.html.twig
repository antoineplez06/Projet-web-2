{% extends "layouts/base.html.twig" %}

{% block title %}Liste des Etudiants
{% endblock %}

{% block content %}
	<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-md-items-center mb-4 gap-2 gap-md-0">
		<h1 class="fs-4 fs-md-3">Liste des étudiants</h1>
		<a class="btn btn-primary btn-sm" href="{{ url_for('ajoute') }}">Ajouter un étudiant</a>
	</div>

	<div class="row mb-3 px-2 px-md-0">
		<div class="col-12 col-md-6">
			<form method="GET" action="{{ url_for('liste-etudiants') }}" class="d-flex flex-column flex-sm-row gap-2">
				<input type="text" name="q" class="form-control form-control-sm" placeholder="Rechercher par nom..." value="{{ searchTerm }}">
				<button type="submit" class="btn btn-outline-secondary btn-sm flex-shrink-0">Rechercher</button>
				{% if searchTerm %}
					<a href="{{ url_for('liste-etudiants') }}" class="btn btn-link btn-sm">Réinitialiser</a>
				{% endif %}
			</form>
		</div>
	</div>

	<div class="card shadow-sm">
		<div class="card-body p-0">
			<div class="table-responsive">
				<table class="table table-hover mb-0 table-sm">
					<thead class="table-light">
						<tr>
							<th class="text-truncate">Prénom</th>
							<th class="text-truncate">Nom</th>
							<th class="d-none d-md-table-cell text-truncate">Genre</th>
							<th class="d-none d-lg-table-cell">Mail</th>
							<th class="d-none d-md-table-cell text-truncate">Campus</th>
							<th class="text-center">Actions</th>
						</tr>
					</thead>
					<tbody>
						{% for etu in etudiant %}
							<tr>
								<td class="text-truncate">{{ etu.prenom }}</td>
								<td class="text-truncate"><strong>{{ etu.nom }}</strong></td>
								<td class="d-none d-md-table-cell text-truncate small">{{ etu.genre }}</td>
								<td class="d-none d-lg-table-cell text-truncate small">{{ etu.email }}</td>
								<td class="d-none d-md-table-cell text-truncate small">{{ etu.campus.ville }}</td>
								<td class="text-center">
									<div class="d-flex gap-1 justify-content-center flex-wrap">
										<a href="{{ url_for('modifier-etudiant', { 'id': etu.id }) }}" class="btn btn-sm btn-outline-warning" title="Modifier">Modifier</a>
										<form action="{{ url_for('supprimer-etudiant', { 'id': etu.id }) }}" method="POST" class="d-inline" onsubmit="return confirm('Supprimer cet étudiant ?')">
											<button type="submit" class="btn btn-sm btn-outline-danger" title="Supprimer">Supprimer</button>
										</form>
									</div>
								</td>
							</tr>
						{% else %}
							<tr>
								<td colspan="6" class="text-center py-4 text-muted">Aucun étudiant trouvé.</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		</div>
	</div>

	<nav aria-label="Page navigation" class="mt-4">
		<ul class="pagination pagination-sm justify-content-center">

			<li class="page-item {{ pageActuelle <= 1 ? 'disabled' }}">
				<a class="page-link" href="{{ url_for('liste-etudiants', { 'page': pageActuelle - 1 }) }}">Précédent</a>
			</li>

			{% for i in 1..nombrePages %}
				<li class="page-item {{ i == pageActuelle ? 'active' }}">
					<a class="page-link" href="{{ url_for('liste-etudiants', { 'page': i }) }}">{{ i }}</a>
				</li>
			{% endfor %}

			<li class="page-item {{ pageActuelle >= nombrePages ? 'disabled' }}">
				<a class="page-link" href="{{ url_for('liste-etudiants', { 'page': pageActuelle + 1 }) }}">Suivant</a>
			</li>

		</ul>
	</nav>

{% endblock %}
