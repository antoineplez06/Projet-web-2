{% extends "layouts/base.html.twig" %}

{% block content %}
	<h1 class="text-center mt-4 fw-bold">Ma Wishlist</h1>

	{% for favori in favoris %}
		{% set offre = favori.offre %}

		<div class="row mt-4 px-2 justify-content-center">
			<div class="col-12 col-sm-10 col-lg-8 col-xl-7">
				<div class="border border-dark border-3 rounded-2 px-3 px-md-5 py-3 bg-white shadow-sm position-relative">
					<div class="d-flex justify-content-between align-items-start gap-3 mb-3">
						<div class="flex-grow-1 min-w-0">
							<h3 class="fw-bold text-break">{{ offre.nom }}</h3>
							<p class="mb-0 text-break">{{ offre.entreprise.nom }}</p>
							<p class="mb-0 text-break">{{ offre.lieu }}</p>
							<p class="mt-3 text-muted small">Publié le :
								{{ offre.date|date("d/m/Y") }}</p>
						</div>

						<div class="dropdown flex-shrink-0">
							<a href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" class="text-decoration-none">
								<svg class="Wishlist" height="40" fill="red" stroke="black" stroke-width="30" viewbox="0 0 512 512" role="button" style="cursor: pointer;">
									<path d="M256 472 C256 472 40 312 40 160 C40 72 104 32 168 32 C216 32 256 80 256 80 C256 80 296 32 344 32 C408 32 472 72 472 160 C472 312 256 472 256 472 Z"/>
								</svg>
							</a>

							<ul class="dropdown-menu dropdown-menu-end border border-dark border-2 shadow">
								<li>
									<a class="dropdown-item text-danger fw-bold" href="/wishlist/remove/{{ favori.idWishlist }}">
										<i class="bi bi-trash"></i>
										Supprimer
									</a>
								</li>
								<li><hr class="dropdown-divider"></li>
								<li>
									<a class="dropdown-item small" href="#">Annuler</a>
								</li>
							</ul>
						</div>
					</div>

					<div class="d-flex justify-content-center mt-4">
						<button type="button" class="btn btn-outline-dark rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#VoirOffre{{ offre.idOffre }}">
							Voir l'offre
						</button>
					</div>

					<div class="modal fade" id="VoirOffre{{ offre.idOffre }}" tabindex="-1">
						<div class="modal-dialog modal-lg modal-dialog-scrollable">
							<div class="modal-content">
								<div class="modal-header flex-column align-items-start border-bottom">
									<button type="button" class="btn-close align-self-end mb-2" data-bs-dismiss="modal"></button>
									<div class="w-100">
										<h2 class="fw-bold text-break">{{ offre.nom }}</h2>
										<p class="mb-1 text-muted small text-break">{{ offre.entreprise.nom }}</p>
										<p class="mb-1 text-muted small text-break">{{ offre.lieu }}</p>
										<p class="mt-2 text-muted small">Publié le :
											{{ offre.date|date('d/m/Y') }}</p>
										<p class="text-dark fw-bold">{{ offre.nombreEtudiantPostule }}
											postulant(s)</p>
									</div>
								</div>
								<div class="modal-body px-3 px-md-4">
									<h4 class="fw-bold">Description</h4>
									<p class="text-break">{{ offre.description|nl2br }}</p>
									<h4 class="fw-bold mt-4">Rémunération</h4>
									<p>{{ offre.remuneration }}
										€</p>
								</div>
								<div class="modal-footer">
									<a href="{{ url_for('page-postuler', { 'id': offre.idOffre }) }}" class="btn btn-primary">Postuler</a>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	{% else %}
		<div class="text-center mt-5 px-3">
			<img src="{{('assets/images/NoWishList.png') }}" alt="Aucune wishlist" class="mx-auto d-block mt-4" style="width: clamp(150px, 80vw, 200px);">
			<h4 class="fw-bold text-muted mt-4 fs-5 fs-md-4">Votre wishlist est vide.</h4>
			<a href="/offres" class="btn btn-success rounded-pill px-3 py-2 mx-auto d-block mt-4">Découvrir des offres</a>
		</div>
	{% endfor %}

	{% if nombrePages > 1 %}
		<nav aria-label="Page navigation" class="mt-4">
			<ul class="pagination justify-content-center">
				<li class="page-item {{ pageActuelle <= 1 ? 'disabled' }}">
					<a class="page-link" href="{{ url_for('entreprises-admin', { 'page': pageActuelle - 1 }) }}">Précédent</a>
				</li>
				{% for i in 1..nombrePages %}
					<li class="page-item {{ i == pageActuelle ? 'active' }}">
						<a class="page-link" href="{{ url_for('entreprises-admin', { 'page': i }) }}">{{ i }}</a>
					</li>
				{% endfor %}
				<li class="page-item {{ pageActuelle >= nombrePages ? 'disabled' }}">
					<a class="page-link" href="{{ url_for('entreprises-admin', { 'page': pageActuelle + 1 }) }}">Suivant</a>
				</li>
			</ul>
		</nav>
	{% endif %}
{% endblock %}
