<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>
            {% block title %}StageHub{% endblock %}
        </title>

        <link rel="stylesheet" href="/assets/css/style-Accueil.css">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    </head>

    <body class="bg-light d-flex flex-column min-vh-100" style="font-family: Inter;">

        <header class="header sticky-top">
            <nav class="navbar navbar-expand-lg navbar-light">
                <div class="container-fluid px-2 px-md-4">
                    
                    <a class="navbar-brand" href="{{ user ? url_for('accueil-co') : url_for('home') }}">
                        <img src="/assets/images/logo.png" alt="StageHub" style="height:100px; max-height: 80px; width: auto;">
                    </a>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menuPrincipal" aria-controls="menuPrincipal" aria-expanded="false" aria-label="Basculer la navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="collapse navbar-collapse" id="menuPrincipal">
                        
                        <ul class="navbar-nav ms-auto me-auto mb-2 mb-lg-0 fs-6 fs-lg-5 gap-2 gap-lg-4 align-items-center">
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="{{ user ? url_for('accueil-co') : url_for('home') }}">Page d'accueil</a>
                            </li>

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Rechercher
                                </a>
                                <ul class="dropdown-menu">
                                    {# --- SECTION OFFRES --- #}
                                    <li>
                                        <a class="dropdown-item" href="{{ user ? url_for('Offres') : url_for('offres-an') }}">Offres</a>
                                    </li>
                                    {% if user and (user.roleValue == 'pilote' or user.roleValue == 'admin') %}
                                        <li>
                                            <a class="dropdown-item text-primary" href="{{ url_for('offres-admin') }}">Offres (Gestion Admin)</a>
                                        </li>
                                    {% endif %}

                                    <li><hr class="dropdown-divider"></li>

                                    {# --- SECTION ENTREPRISES --- #}
                                    <li>
                                        <a class="dropdown-item" href="{{ user ? url_for('liste-entreprises') : url_for('entreprises-an') }}">Entreprises</a>
                                    </li>
                                    {% if user and (user.roleValue == 'pilote' or user.roleValue == 'admin') %}
                                        <li>
                                            <a class="dropdown-item text-primary" href="{{ url_for('entreprises-admin') }}">Entreprises (Gestion Admin)</a>
                                        </li>
                                    {% endif %}

                                    {# --- AUTRES MENUS --- #}
                                    {% if user and (user.roleValue == 'pilote' or user.roleValue == 'admin') %}
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <a class="dropdown-item" href="{{ url_for('liste-etudiants') }}">Étudiants</a>
                                        </li>
                                    {% endif %}

                                    {% if user and user.roleValue == 'admin' %}
                                        <li>
                                            <a class="dropdown-item" href="{{ url_for('liste-pilotes') }}">Pilotes</a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" href="{{ url_for('campus-admin') }}">Campus (Gestion Admin)</a>
                                        </li>
                                    {% endif %}
                                </ul>
                            </li>
                        </ul>

                        <div class="d-flex flex-wrap align-items-center justify-content-center gap-3 mt-3 mt-lg-0">
                            {% if user %}
                                {% if user.roleValue == 'etudiant' %}
                                    <a href="{{ url_for('wishlist') }}" title="Ma wishlist">
                                        <svg class="Wishlist" height="40" fill="none" stroke="black" stroke-width="30" viewbox="0 0 512 512">
                                            <path d="M256 472 C256 472 40 312 40 160 C40 72 104 32 168 32 C216 32 256 80 256 80 C256 80 296 32 344 32 C408 32 472 72 472 160 C472 312 256 472 256 472 Z"/>
                                        </svg>
                                    </a>
                                {% endif %}

                                {% if user.roleValue == 'etudiant' or user.roleValue == 'pilote' or user.roleValue == 'admin' %}
                                    <a href="{{ url_for('candidatures') }}" title="{% if user.roleValue == 'etudiant' %}Mes candidatures{% else %}Candidatures des étudiants{% endif %}">
                                        <svg class="Candidatures" height="45" fill="none" stroke="black" stroke-width="30" viewbox="0 0 512 512">
                                            <path d="M160 64 H352 L416 128 V448 H160 Z M352 64 V128 H416 M112 96 L208 288 L176 320 L80 128 Z"/>
                                        </svg>
                                    </a>
                                {% endif %}

                                <div class="nav-item dropdown">
                                    <a href="#" class="nav-link dropdown-toggle d-flex align-items-center text-dark" id="Profildéroulant" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <svg class="Profil" height="50" stroke="black" fill="none" stroke-width="35" viewbox="0 0 512 512">
                                            <circle cx="256" cy="160" r="96"/>
                                            <path d="M96 416 C96 336 176 304 256 304 C336 304 416 336 416 416"/>
                                        </svg>
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end shadow">
                                        <li class="text-center fw-bold border-bottom border-light px-3 pb-2 mb-2">
                                            {{ user.prenom }} {{ user.nom }}
                                        </li>
                                        <li>
                                            <a class="dropdown-item text-center text-danger fw-bold" href="{{ url_for('deconnexion') }}">
                                                Me déconnecter
                                            </a>
                                        </li>
                                    </ul>
                                </div>

                            {% else %}
                                <a href="{{ url_for('connexion') }}" class="fs-5 btn rounded-pill px-4 py-2 text-dark border border-dark" style="background-color: #8FB4B0;">
                                    Connexion
                                </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </nav>
        </header>

        <main class="container-fluid container-xl py-3 py-md-4 flex-grow-1">
            {% block content %}{% endblock %}
        </main>

     <footer id="footer" class="py-4 mt-auto bg-light border-top">
    <div class="container">
        {% block footer %}
            <div class="row align-items-center">
                
                <div class="col-12 col-md-4 mb-4 mb-md-0 text-center text-md-start">
                    <h3 class="mb-3 text-dark" style="font-family: 'Pacifico', cursive; font-size: 1.5rem;">
                        Explorer
                    </h3>
                    <ul class="nav flex-column">
                        
                        <li class="nav-item mb-1">
                            <a class="p-0 text-muted text-decoration-none small" 
                               href="{% if user %}{{ url_for('accueil-co') }}{% else %}{{ url_for('home') }}{% endif %}">
                                Page d'accueil
                            </a>
                        </li>

                        <li class="nav-item mb-1">
                            <a class="p-0 text-muted text-decoration-none small" 
                               href="{% if user %}{{ url_for('Offres') }}{% else %}{{ url_for('offres-an') }}{% endif %}">
                                Offres
                            </a>
                        </li>

                        <li class="nav-item mb-1">
                            <a class="p-0 text-muted text-decoration-none small" 
                               href="{% if user %}{{ url_for('liste-entreprises') }}{% else %}{{ url_for('entreprises-an') }}{% endif %}">
                                Entreprises
                            </a>
                        </li>

                    </ul>
                </div>

                <div class="col-12 col-md-4 text-center">
                    <span class="text-muted small">&copy; Copyright 2026 by</span>
                    <a href="{{ url_for('mentionslégales') }}" class="text-decoration-none text-dark fw-bold ms-1">
                        StageHub
                    </a>
                </div>

                <div class="col-md-4 d-none d-md-block"></div>

            </div>
        {% endblock %}
    </div>
</footer>

    </body>
</html>