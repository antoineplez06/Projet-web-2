<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StageHub</title>
    <link rel="stylesheet" href="/assets/css/style-Accueil.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    
</head>

<body class="bg-light" style="font-family: Inter;">

    <header class="header d-flex align-items-center gap-4">
        
        <img src="/assets/images/logo.png" alt="StageHub" style="height:100px;">

                <nav class="d-flex justify-content-center align-items-start gap-4 list-unstyled fs-5">
                    <a class="text-decoration-none text-dark" href="/">
                     <li>Page d'accueil</li>
                    </a>
                     <li class="Rechercher dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        Rechercher
                        </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="/offres-an">Offres</a></li>
                                <li><a class="dropdown-item" href="/entreprises-an">Entreprises</a></li>
                            </ul>
                    </li>
                </nav>

                <a href="/connexion" title="connexion" class="ms-auto list-unstyled fs-5 btn btn-outline-primary rounded-pill px-3 py-2 pe-4 me-4 text-dark border border-dark" style="background-color: #8FB4B0">
                Connexion</a>

                
    </header>
        {% block content %}{% endblock %}

        <footer id="footer" class="text-center mb-3">
            {% block footer %}
