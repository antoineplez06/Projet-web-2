{% extends "base.html.twig" %}

{% block title %}Liste des Entreprises{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Liste des Entreprises</h1>
    <a class="btn btn-primary" href="{{ url_for('ajout-entreprise') }}">Ajouter une entreprise</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Nom</th>
                    <th>Adresse</th>
                    <th>SIRET</th>
                    <th>Domaine</th>
                    <th>Taille</th>
                    <th class="text-end px-3">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for ent in entreprises %}
                <tr>
                    <td class="text-muted">{{ ent.id }}</td>
                    <td><strong>{{ ent.nom }}</strong></td>
                    <td>{{ ent.adresse }}</td>
                    <td><code>{{ ent.siret }}</code></td>
                    <td>{{ ent.domaine }}</td>
                    <td>
                        <span class="badge border text-dark bg-light">{{ ent.taille }}</span>
                    </td>
                    <td class="text-end px-3">
                        <div class="btn-group">
                            <a href="#" class="btn btn-sm btn-outline-info">Voir</a>
                            <a href="#" class="btn btn-sm btn-outline-danger">Supprimer</a>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="7" class="text-center py-4 text-muted">
                        Aucune entreprise trouvée dans la base de données.
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{# Pagination #}
{% if nombrePages > 1 %}
<nav aria-label="Page navigation" class="mt-4">
  <ul class="pagination justify-content-center">
    <li class="page-item {{ pageActuelle <= 1 ? 'disabled' }}">
      <a class="page-link" href="{{ url_for('liste-entreprises', { 'page': pageActuelle - 1 }) }}">Précédent</a>
    </li>

    {% for i in 1..nombrePages %}
      <li class="page-item {{ i == pageActuelle ? 'active' }}">
        <a class="page-link" href="{{ url_for('liste-entreprises', { 'page': i }) }}">{{ i }}</a>
      </li>
    {% endfor %}

    <li class="page-item {{ pageActuelle >= nombrePages ? 'disabled' }}">
      <a class="page-link" href="{{ url_for('liste-entreprises', { 'page': pageActuelle + 1 }) }}">Suivant</a>
    </li>
  </ul>
</nav>
{% endif %}

{% endblock %}