{% extends "base.html.twig" %}

{% block title %}Liste des Entreprises{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Liste des étudiants</h1>
    <a class="btn btn-primary" href="{{ url_for('ajout-etudiant') }}">Ajouter un étudiant</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>prenom</th>
                    <th>nom</th>
                    <th>mail</th>
                    <th>campus</th>
                    <th>promo</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for etu in etudiant %}
                <tr>
                    <td>{{ etu.id }}</td>
                    <td>{{ etu.prenom }}</td>
                    <td><strong>{{ etu.nom }}</strong></td>
                    <td>{{ etu.mail }}</td>
                    <td>{{ etu.campus }}</td>
                    <td>{{ etu.promo }}</td>



                    <td class="text-end">
                        <a href="#" class="btn btn-sm btn-outline-info">Voir</a>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="5" class="text-center py-4">Aucun étudiant trouvé.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>


<nav aria-label="Page navigation">
  <ul class="pagination">
    
    <li class="page-item {{ pageActuelle <= 1 ? 'disabled' }}">
      <a class="page-link" href="{{ url_for('liste-etudiant', { 'page': pageActuelle - 1 }) }}">Précédent</a>
    </li>

    {% for i in 1..nombrePages %}
      <li class="page-item {{ i == pageActuelle ? 'active' }}">
        <a class="page-link" href="{{ url_for('liste-etudiant', { 'page': i }) }}">{{ i }}</a>
      </li>
    {% endfor %}

    <li class="page-item {{ pageActuelle >= nombrePages ? 'disabled' }}">
      <a class="page-link" href="{{ url_for('liste-etudiant', { 'page': pageActuelle + 1 }) }}">Suivant</a>
    </li>

  </ul>
</nav>

{% endblock %}