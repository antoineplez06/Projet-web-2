{% extends "layouts/base.html.twig" %}

{% block title %}Ajouter une offre
{% endblock %}

{% block content %}
	<div class="row justify-content-center mt-5">
		<div class="col-md-8">
			<div class="card shadow border-0">
				<div class="card-header bg-primary text-white py-3">
					<h4 class="mb-0">
						<i class="bi bi-plus-circle me-2"></i>Nouvelle Offre de Stage</h4>
				</div>
				<div class="card-body p-4">
					<form action="{{ url_for('ajout-offre') }}" method="POST">
						<div class="row">
							<div class="col-md-6 mb-3">
								<label for="nom" class="form-label fw-bold">Intitulé du poste (nom)</label>
								<input type="text" class="form-control" id="nom" name="nom" placeholder="Ex: Développeur Fullstack" required>
							</div>
							<div class="col-md-6 mb-3">
								<label for="entreprise" class="form-label fw-bold">Entreprise</label>
								<input type="text" class="form-control" id="entreprise" name="entreprise" placeholder="Nom de la société" required>
							</div>
						</div>

						<div class="row">
							<div class="col-md-6 mb-3">
								<label for="duree" class="form-label fw-bold">Durée du stage</label>
								<input type="text" class="form-control" id="duree" name="duree" placeholder="Ex: 4 mois, 6 mois..." required>
							</div>
							<div class="col-md-6 mb-3">
								<label for="date" class="form-label fw-bold">Date de début / Publication</label>
								<input type="date" class="form-control" id="date" name="date" required>
							</div>
						</div>

						<div class="row">
							<div class="col-md-6 mb-3">
								<label for="remuneration" class="form-label fw-bold">Rémunération (€)</label>
								<input type="number" step="0.01" class="form-control" id="remuneration" name="remuneration" placeholder="Ex: 600.50" required>
							</div>
							<div class="col-md-6 mb-3">
								<label for="presentielOuDistanciel" class="form-label fw-bold">Mode de travail</label>
								<select class="form-select" id="presentielOuDistanciel" name="presentielOuDistanciel" required>
									<option value="" selected disabled>Choisir...</option>
									<option value="Présentiel">Présentiel</option>
									<option value="Distanciel">Distanciel</option>
									<option value="Hybride">Hybride</option>
								</select>
							</div>
						</div>

						<div class="mb-3">
							<label for="exigenceEtude" class="form-label fw-bold">Exigences d'études
							</label>
							<input type="text" class="form-control" id="exigenceEtude" name="exigenceEtude" placeholder="Ex: Bac+3, Master, PHP, React..." required>
						</div>

						<div class="mb-3">
							<label for="description" class="form-label fw-bold">Description détaillée</label>
							<textarea class="form-control" id="description" name="description" rows="5" placeholder="Détaillez les missions de l'offre..." required></textarea>
						</div>

						<hr class="my-4">

						<div class="d-flex justify-content-between">
							<a href="/offres" class="btn btn-outline-secondary px-4">Annuler</a>
							<button type="submit" class="btn btn-success px-5 fw-bold">Enregistrer l'offre</button>
						</div>

					</form>
				</div>
			</div>
		</div>
	</div>

	{% if success %}
		<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">
			<div class="alert alert-success alert-dismissible fade show shadow" role="alert">
				<strong>Succès !</strong>
				L'offre a été ajoutée à la base de données.
				<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
			</div>
		</div>
	{% endif %}
{% endblock %}
