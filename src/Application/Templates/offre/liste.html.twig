{% extends "layouts/base.html.twig" %}

{% block content %}

    {# ... Ton formulaire de recherche reste identique ... #}
    <form class="d-flex mt-4 mx-auto w-50" method="GET" action="">
        <input class="form-control me-4 border border-dark border-2" type="search" name="search" value="{{ filtres.search|default('') }}" placeholder="Rechercher par nom d'offre ou entreprise" aria-label="Rechercher une offre"/>
        <button class="btn btn-outline-secondary" type="submit">Rechercher</button>
    </form>

    {# ... Ton code de filtres et modal filtre reste identique ... #}

    {% for offre in offres %}
        <div class="border border-dark border-3 rounded-2 px-5 py-3 w-50 mx-auto mt-4 position-relative bg-white">
            <h3 class="float-none w-auto fw-bold">{{ offre.nom }}</h3>
            
            {# --- CORRECTION ICI : on ajoute .nom --- #}
            <p class="mb-0">{{ offre.entreprise.nom }}</p> 
            
            <p class="mb-0">{{ offre.lieu }}</p>
            <p class="mt-4 text-muted">Publié le :
                {{ offre.date|date("d/m/Y") }}
            </p>
            
            {# ... Bouton Wishlist ... #}
            <div class="position-absolute top-0 end-0 mt-3 me-3">
                <a href="{{ url_for('app_wishlist_add', { 'idOffre': offre.idOffre }) }}" class="btn-wishlist">
                    <svg class="Wishlist" height="45" fill="none" stroke="black" stroke-width="30" viewbox="0 0 512 512" role="button" style="cursor: pointer;">
                        <path d="M256 472 C256 472 40 312 40 160 C40 72 104 32 168 32 C216 32 256 80 256 80 C256 80 296 32 344 32 C408 32 472 72 472 160 C472 312 256 472 256 472 Z"/>
                    </svg>
                </a>
            </div>

            <button type="button" class="border border-dark rounded-pill px-4 py-2 position-absolute bottom-0 end-0 mb-3 me-3 bg-light hover-shadow" data-bs-toggle="modal" data-bs-target="#VoirOffre{{ offre.idOffre }}">
                Voir l'offre
            </button>

            {# MODAL DÉTAIL OFFRE #}
            <div class="modal fade" id="VoirOffre{{ offre.idOffre }}" tabindex="-1">
                <div class="modal-dialog modal-xl">
                    <div class="modal-content">
                        <div class="modal-header">
                            <div class="container-fluid">
                                <div class="row w-100 align-items-center">
                                    <div class="col-md-8">
                                        <h2 class="fw-bold">{{ offre.nom }}</h2>
                                        
                                        {# --- CORRECTION ICI AUSSI --- #}
                                        <p class="mb-1 text-muted">{{ offre.entreprise.nom }}</p>
                                        
                                        <p class="mt-0 mb-1 text-muted">{{ offre.lieu }}</p>
                                        <p class="mt-3 mb-0 text-muted small">Publié le :
                                            {{ offre.date|date('d/m/Y') }}</p>
                                    </div>
                                    <div class="col-md-4 text-center">
                                        <p class="text-dark fw-bold mb-0" style="font-size: 1.1rem;">
                                            {{ offre.nombreEtudiantPostule }} {# Attention: verifie si c'est .candidats ou .nombreEtudiantPostule dans ton entité #}
                                            personne(s) ont déjà postulé
                                        </p>
                                    </div>
                                </div>
                            </div>
                            <button type="button" class="btn-close position-absolute top-0 end-0 me-3 mt-3" data-bs-dismiss="modal"></button>
                        </div>

                        <div class="modal-body p-4">
                            <h4 class="fw-bold">Description de l'offre</h4>
                            <p>{{ offre.description|nl2br }}</p>

                            <h4 class="fw-bold mt-4">Niveau d'études requises</h4>
                            <p>{{ offre.exigenceEtude }}</p>

                            <h4 class="fw-bold mt-4">Rémunération</h4>
                            <p>{{ offre.remuneration }} €</p>
                        </div>

                        <div class="modal-footer">
                            <a href="{{ url_for('page-postuler', { 'id': offre.idOffre }) }}" class="btn btn-primary btn-lg">Postuler maintenant</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    {% else %}
        <div class="text-center mt-5">
            <h4 class="fw-bold text-muted">Aucune offre ne correspond à vos critères.</h4>
        </div>
    {% endfor %}

			{# Bouton Suivant #}
			<li class="page-item {{ pageActuelle >= nombrePages ? 'disabled' : '' }}">
				<a class="page-link text-dark" href="{{ url_for('Offres', { 'page': pageActuelle + 1 }, filtres) }}">Suivant</a>
			</li>

		</ul>
	</nav>

{% endblock %}
