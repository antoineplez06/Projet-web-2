{% extends "layouts/base.html.twig" %}

{% block content %}

	<form class="d-flex mt-4 mx-auto w-50" method="GET" action="">
		<input class="form-control me-4 border border-dark border-2" type="search" name="search" value="{{ filtres.search|default('') }}" placeholder="Rechercher par nom d'offre ou entreprise" aria-label="Rechercher une offre"/>
		<button class="btn btn-outline-secondary" type="submit">Rechercher</button>
	</form>

	{% for offre in offres %}
		<div class="border border-dark border-3 rounded-2 px-5 py-3 w-50 mx-auto mt-4 position-relative bg-white">
			<div class="d-flex justify-content-between align-items-start">
				<div>
					<h3 class="fw-bold mb-0">{{ offre.nom }}</h3>
					<p class="mb-0 text-secondary">{{ offre.entreprise.nom }}</p>
					<p class="mb-0 text-muted">{{ offre.lieu }}</p>
				</div>
				<a href="{{ url_for('app_wishlist_add', { 'idOffre': offre.idOffre }) }}" class="btn-wishlist">
					<svg height="45" fill="none" stroke="black" stroke-width="30" viewbox="0 0 512 512" style="cursor:pointer">
						<path d="M256 472 C256 472 40 312 40 160 C40 72 104 32 168 32 C216 32 256 80 256 80 C256 80 296 32 344 32 C408 32 472 72 472 160 C472 312 256 472 256 472 Z"/>
					</svg>
				</a>
			</div>
			<hr
			class="my-3">

			{# ── Carousel des caractéristiques ── #}
			<div id="carouselOffre{{ offre.idOffre }}" class="carousel slide" data-bs-ride="false">
				<div class="carousel-inner">
					<div class="carousel-item active">
						<p class="text-uppercase text-muted small fw-semibold mb-1">Description</p>
						<p class="mb-0">{{ offre.description|slice(0, 150) }}
							{% if offre.description|length > 150 %}…
							{% endif %}
						</p>
					</div>
					<div class="carousel-item">
						<p class="text-uppercase text-muted small fw-semibold mb-1">Niveau d'études requis</p>
						<p class="fs-5 fw-bold mb-0">{{ offre.exigenceEtude }}</p>
					</div>
					<div class="carousel-item">
						<p class="text-uppercase text-muted small fw-semibold mb-1">Rémunération</p>
						<p class="fs-4 fw-bold mb-0">{{ offre.remuneration }}</p>
					</div>
					<div class="carousel-item">
						<p class="text-uppercase text-muted small fw-semibold mb-1">Candidatures reçues</p>
						<p class="mb-0">
							<span class="fs-3 fw-bold">{{ offre.nombreEtudiantPostule }}</span>
							<span class="text-muted">personne(s) ont déjà postulé</span>
						</p>
					</div>
					<div class="carousel-item">
						<p class="text-uppercase text-muted small fw-semibold mb-1">Publié le</p>
						<p class="fs-5 mb-0">{{ offre.date|date("d/m/Y") }}</p>
					</div>
				</div>
				<div class="d-flex justify-content-between align-items-center mt-3">
					<button class="btn btn-sm btn-outline-dark rounded-circle" type="button" data-bs-target="#carouselOffre{{ offre.idOffre }}" data-bs-slide="prev">
						&#8592;
					</button>

					<button class="btn btn-sm btn-outline-dark rounded-circle" type="button" data-bs-target="#carouselOffre{{ offre.idOffre }}" data-bs-slide="next">
						&#8594;
					</button>
				</div>
			</div>

			<div class="mt-3 text-end">
				<a href="{{ url_for('page-postuler', { 'id': offre.idOffre }) }}" class="btn btn-dark rounded-pill px-4">
					Postuler maintenant
				</a>
			</div>
		</div>
	{% else %}
		<div class="text-center mt-5">
			<h4 class="fw-bold text-muted">Aucune offre ne correspond à vos critères.</h4>
		</div>
	{% endfor %}

	<nav>
		<ul>
			<li class="page-item {{ pageActuelle >= nombrePages ? 'disabled' : '' }}">
				<a class="page-link text-dark" href="{{ url_for('Offres', { 'page': pageActuelle + 1 }, filtres) }}">Suivant</a>
			</li>
		</ul>
	</nav>

{% endblock %}
