{% extends "layouts/base.html.twig" %}

{% block title %}Liste des Offres
{% endblock %}

{% block content %}

	{# En-tête : Titre à gauche, bouton à droite (Style "Entreprises") #}
	<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-md-items-center mt-4 mb-4 gap-2 gap-md-0">
		<h1 class="fs-4 fs-md-3">Liste des Offres</h1>
		<a class="btn btn-primary btn-sm" href="{{ url_for('ajout-offre') }}">Ajouter une offre</a>
	</div>

	<div class="row mb-3 px-2 px-md-0">
		<div class="col-12 col-md-6">
			<form method="GET" action="{{ url_for('offres-admin') }}" class="d-flex flex-column flex-sm-row gap-2">
				<input type="text" name="q" class="form-control form-control-sm" placeholder="Rechercher par nom..." value="{{ searchTerm }}">
				<button type="submit" class="btn btn-outline-secondary btn-sm flex-shrink-0">Rechercher</button>
				{% if searchTerm %}
					<a href="{{ url_for('offres-admin') }}" class="btn btn-link btn-sm">Réinitialiser</a>
				{% endif %}
			</form>
		</div>
	</div>

	{# Modale des filtres (Inchangé, c'est ta logique) #}
	<div class="modal fade" id="filtreModal" tabindex="-1" aria-labelledby="filtreModalLabel" aria-hidden="true">
		<div class="modal-dialog">
			<div class="modal-content">
				<form method="GET" action="{{ url_for('offres-admin') }}">
					<input type="hidden" name="search" value="{{ filtres.search|default('') }}">
					<div class="modal-header">
						<h2 class="modal-title fs-5" id="filtreModalLabel">Filtrer les offres</h2>
						<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
					</div>
					<div class="modal-body">
						<div class="mb-3">
							<label class="form-label fw-semibold">Lieu</label>
							<select name="lieu" class="form-select">
								<option value="">Tous les lieux</option>
								<option value="Paris" {% if filtres.lieu|default('') == 'Paris' %} selected {% endif %}>Paris</option>
								<option value="Lyon" {% if filtres.lieu|default('') == 'Lyon' %} selected {% endif %}>Lyon</option>
								<option value="Toulouse" {% if filtres.lieu|default('') == 'Toulouse' %} selected {% endif %}>Toulouse</option>
								<option value="Marseille" {% if filtres.lieu|default('') == 'Marseille' %} selected {% endif %}>Marseille</option>
								<option value="Strasbourg" {% if filtres.lieu|default('') == 'Strasbourg' %} selected {% endif %}>Strasbourg</option>
							</select>
						</div>
						<div class="mb-3">
							<label class="form-label fw-semibold">Candidats maximum</label>
							<input type="number" name="candidats_max" class="form-control" placeholder="Ex: 10" value="{{ filtres.candidats_max|default('') }}">
						</div>
					</div>
					<div class="modal-footer">
						<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fermer</button>
						<button type="submit" class="btn btn-primary">Appliquer les filtres</button>
					</div>
				</form>
			</div>
		</div>
	</div>

	{# Tableau d'administration (Même structure que ton modèle) #}
	<div class="card shadow-sm">
		<div class="card-body p-0">
			<div class="table-responsive">
				<table class="table table-hover mb-0 table-sm">
					<thead class="table-light">
						<tr>
							<th class="text-truncate">Intitulé</th>
							<th class="d-none d-md-table-cell text-truncate">Entreprise</th>
							<th class="d-none d-lg-table-cell text-truncate">Lieu</th>
							<th class="d-none d-lg-table-cell text-center">Pub.</th>
							<th>Cand.</th>
							<th class="text-center">Actions</th>
						</tr>
					</thead>
					<tbody>
						{% for offre in offres %}
							<tr>
								<td class="text-truncate">
									<strong>{{ offre.nom }}</strong>
								</td>
								<td class="d-none d-md-table-cell text-truncate small">{{ offre.entreprise.nom }}</td>
								<td class="d-none d-lg-table-cell text-truncate small">{{ offre.campus.ville|default('-') }}</td>
								<td class="d-none d-lg-table-cell text-center small">{{ offre.date|date("d/m/y") }}</td>
								<td class="text-center">
									<span class="badge border text-dark bg-light">{{ offre.candidatures|length }}</span>
								</td>
								<td class="text-center">
									<div class="d-flex gap-1 justify-content-center flex-wrap">
										<button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#VoirOffre{{ offre.idOffre }}" title="Voir">Voir</button>
										<a href="{{ url_for('modifier-offre', { 'id': offre.idOffre })|default('#') }}" class="btn btn-sm btn-outline-warning" title="Modifier">Mod.</a>
										<form action="{{ url_for('supprimer-offre', { 'id': offre.idOffre })|default('#') }}" method="POST" class="d-inline" onsubmit="return confirm('Voulez-vous vraiment supprimer cette offre ?')">
											<button type="submit" class="btn btn-sm btn-outline-danger" title="Supprimer">Sup.</button>
										</form>
									</div>
								</td>
							</tr>

							<div class="modal fade" id="VoirOffre{{ offre.idOffre }}" tabindex="-1">
								<div class="modal-dialog modal-lg modal-dialog-scrollable">
									<div class="modal-content">
										<div class="modal-header bg-light flex-column align-items-start border-bottom">
											<button type="button" class="btn-close align-self-end mb-2" data-bs-dismiss="modal"></button>
											<div class="w-100">
												<h3 class="fw-bold mb-0 text-break">{{ offre.nom }}</h3>
												<p class="mb-1 text-muted small text-break">{{ offre.entreprise.nom }}
													-
													{{ offre.lieu|default('Lieu non précisé') }}</p>
												<p class="text-dark fw-bold">Candidatures :
													{{ offre.candidatures|length }}</p>
											</div>
										</div>
										<div class="modal-body px-3 px-md-4">
											<div class="row mb-3">
												<div class="col-12 col-md-6">
													<p class="mb-2">
														<strong>Date de publication :</strong><br>{{ offre.date|date('d/m/Y') }}</p>
													<p class="mb-2">
														<strong>Rémunération :</strong><br>{{ offre.remuneration|default('Non renseignée') }}
														€</p>
												</div>
												<div class="col-12 col-md-6">
													<p class="mb-2">
														<strong>Niveau requis :</strong><br>{{ offre.exigenceEtude|default('Non renseigné') }}</p>
												</div>
											</div>
											<h5 class="fw-bold border-bottom pb-2 mt-4">Description</h5>
											<p style="white-space: pre-line;" class="text-muted text-break">{{ offre.description }}</p>
										</div>
										<div class="modal-footer">
											<button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Fermer</button>
										</div>
									</div>
								</div>
							</div>

						{% else %}
							<tr>
								<td colspan="6" class="text-center py-4 text-muted">
									Aucune offre trouvée dans la base de données.
								</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		</div>
	</div>

	{# Pagination (Identique au modèle d'entreprise) #}
	{% if nombrePages > 1 %}
		<nav aria-label="Page navigation" class="mt-4">
			<ul class="pagination justify-content-center">
				<li class="page-item {{ pageActuelle <= 1 ? 'disabled' }}">
					<a class="page-link" href="{{ url_for('offres-admin', { 'page': pageActuelle - 1 }) }}">Précédent</a>
				</li>
				{% for i in 1..nombrePages %}
					<li class="page-item {{ i == pageActuelle ? 'active' }}">
						<a class="page-link" href="{{ url_for('offres-admin', { 'page': i }) }}">{{ i }}</a>
					</li>
				{% endfor %}
				<li class="page-item {{ pageActuelle >= nombrePages ? 'disabled' }}">
					<a class="page-link" href="{{ url_for('offres-admin', { 'page': pageActuelle + 1 }) }}">Suivant</a>
				</li>
			</ul>
		</nav>
	{% endif %}

{% endblock %}
