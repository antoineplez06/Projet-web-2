{% extends "layouts/base_anonyme.html.twig" %}

{% block content %}

	<form class="d-flex mt-4 mx-auto w-50" method="GET" action="/offres-an">
		<input class="form-control me-4 border border-dark border-2" type="search" name="search" value="{{ filtres.search|default('') }}" placeholder="Rechercher par nom d'offre ou entreprise" aria-label="Rechercher une offre"/>
		<button class="btn btn-outline-secondary" type="submit">Rechercher</button>
	</form>

	{% if filtres.search or filtres.lieu or filtres.candidats_max %}
		<div class="text-center mt-3">
			<a href="{{ url_for('offres-an') }}" class="btn btn-sm btn-outline-danger">Réinitialiser les filtres</a>
		</div>
	{% endif %}

	
	{% for offre in offres %}
		<div class="border border-dark border-3 rounded-2 px-5 py-3 w-50 mx-auto mt-4 position-relative bg-white">
			<h3 class="float-none w-auto fw-bold">{{ offre.nom }}</h3>
			<p class="mb-0">{{ offre.entreprise }}</p>
			<p class="mb-0">{{ offre.lieu }}</p>
			<p class="mt-4 text-muted">Publié le :
				{{ offre.date_publication }}</p>

			<button type="button" class="border border-dark rounded-pill px-4 py-2 position-absolute bottom-0 end-0 mb-3 me-3 bg-light hover-shadow" data-bs-toggle="modal" data-bs-target="#VoirOffre{{ offre.id }}">
				Voir l'offre
			</button>

			<div class="modal fade" id="VoirOffre{{ offre.id }}" tabindex="-1">
				<div class="modal-dialog modal-xl">
					<div class="modal-content">
						<div class="modal-header">
							<div class="container-fluid">
								<div class="row w-100 align-items-center">
									<div class="col-md-8">
										<h2 class="fw-bold">{{ offre.nom }}</h2>
										<p class="mb-1 text-muted">{{ offre.entreprise }}</p>
										<p class="mt-0 mb-1 text-muted">{{ offre.lieu }}</p>
										<p class="mt-3 mb-0 text-muted small">Publié le :
											{{ offre.date_publication }}</p>
									</div>
									<div class="col-md-4 text-center">
										<p class="text-dark fw-bold mb-0" style="font-size: 1.1rem;">
											{{ offre.candidats }}
											personne(s) ont déjà postulé
										</p>
									</div>
								</div>
							</div>
							<button type="button" class="btn-close position-absolute top-0 end-0 me-3 mt-3" data-bs-dismiss="modal"></button>
						</div>

						<div class="modal-body p-4">
							<h4 class="fw-bold">Description de l'offre</h4>
							<p>{{ offre.description }}</p>

							<h4 class="fw-bold mt-4">Compétences requises</h4>
							<p>{{ offre.competences }}</p>

							<h4 class="fw-bold mt-4">Rémunération</h4>
							<p>{{ offre.remuneration }}</p>
						</div>

						<div class="modal-footer">
							<a href="{{ url_for('connexion') }}" class="btn btn-primary btn-lg">Se connecter pour postuler</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	{% else %}
		<div class="text-center mt-5">
			<h4 class="fw-bold text-muted">Aucune offre ne correspond à vos critères.</h4>
		</div>
	{% endfor %}
<nav aria-label="Page navigation" class="mt-4">
  <ul class="pagination justify-content-center">
    
    {# Bouton Précédent #}
    <li class="page-item {{ pageActuelle <= 1 ? 'disabled' : '' }}">
      <a class="page-link text-dark" href="{{ url_for('Offres', { 'page': pageActuelle - 1 }, filtres) }}">Précédent</a>
    </li>

    {# Numéros de pages #}
    {% for i in 1..nombrePages %}
      <li class="page-item {{ i == pageActuelle ? 'active' : '' }}">
        {# On passe 'filtres' comme troisième argument à url_for pour conserver les paramètres GET #}
        <a class="page-link {{ i == pageActuelle ? 'bg-dark text-white' : 'text-dark' }}" 
           href="{{ url_for('Offres', { 'page': i }, filtres) }}">{{ i }}</a>
      </li>
    {% endfor %}

    {# Bouton Suivant #}
    <li class="page-item {{ pageActuelle >= nombrePages ? 'disabled' : '' }}">
      <a class="page-link text-dark" href="{{ url_for('Offres', { 'page': pageActuelle + 1 }, filtres) }}">Suivant</a>
    </li>

  </ul>
</nav>

{% endblock %}
