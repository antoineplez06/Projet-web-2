{% extends "layouts/base.html.twig" %}

{% block title %}Liste des pilotes
{% endblock %}

{% block content %}
	<div class="d-flex justify-content-between align-items-center mb-4">
		<h1>Liste des pilotes</h1>
		<a class="btn btn-primary" href="{{ url_for('ajout-pilote') }}">Ajouter un pilote</a>
	</div>


	<div class="row mb-3">
		<div class="col-md-6">
			<form method="GET" action="{{ url_for('liste-pilotes') }}" class="d-flex">
				<input type="text" name="q" class="form-control me-2" placeholder="Rechercher par nom..." value="{{ searchTerm }}">
				<button type="submit" class="btn btn-outline-secondary">Rechercher</button>
				{% if searchTerm %}
					<a href="{{ url_for('liste-pilotes') }}" class="btn btn-link">Réinitialiser</a>
				{% endif %}
			</form>
		</div>
	</div>

	<div class="card shadow-sm">
		<div class="card-body p-0">
			<div class="table-responsive">
				<table class="table table-hover mb-0">
					<thead class="table-light">
						<tr>
							<th>ID</th>
							<th>Prénom</th>
							<th>Nom</th>
							<th>Genre</th>
							<th>Numéro</th>
							<th>Date de naissance</th>
							<th>Mail</th>
							<th>Campus</th>
							<th class="text-end">Actions</th>
						</tr>
					</thead>
					<tbody>
						{% for pil in pilote %}
							<tr>
								<td>{{ pil.id }}</td>
								<td>{{ pil.prenom }}</td>
								<td>
									<strong>{{ pil.nom }}</strong>
								</td>
								<td>{{ pil.genre }}</td>
								<td>{{ pil.numeroTelephone }}</td>
								<td>{{ pil.dateNaissance|date("d/m/Y") }}</td>
								<td>{{ pil.email }}</td>
								<td>{{ pil.campus.ville }}</td>

								<td class="text-end text-nowrap">
									<a href="{{ url_for('modifier-pilote', { 'id': pil.id }) }}" class="btn btn-sm btn-outline-warning">Modifier</a>
									<form action="{{ url_for('supprimer-pilote', { 'id': pil.id }) }}" method="POST" class="d-inline" onsubmit="return confirm('Supprimer ce pilote ?')">
										<button type="submit" class="btn btn-sm btn-outline-danger">Supprimer</button>
									</form>
								</td>
							</tr>
						{% else %}
							<tr>
								<td colspan="9" class="text-center py-4 text-muted">Aucun pilote trouvé.</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		</div>
	</div>
	{% if nombrePages > 1 %}
		<nav aria-label="Page navigation" class="mt-4">
			<ul class="pagination justify-content-center">
				<li class="page-item {{ pageActuelle <= 1 ? 'disabled' }}">
					<a class="page-link" href="{{ url_for('liste-pilotes', { 'page': pageActuelle - 1 }) }}">Précédent</a>
				</li>
				{% for i in 1..nombrePages %}
					<li class="page-item {{ i == pageActuelle ? 'active' }}">
						<a class="page-link" href="{{ url_for('liste-pilotes', { 'page': i }) }}">{{ i }}</a>
					</li>
				{% endfor %}
				<li class="page-item {{ pageActuelle >= nombrePages ? 'disabled' }}">
					<a class="page-link" href="{{ url_for('liste-pilotes', { 'page': pageActuelle + 1 }) }}">Suivant</a>
				</li>
			</ul>
		</nav>
	{% endif %}
{% endblock %}
